# Optional custom paths for database and backups
# CANYU_SECRET_KEY=replace_with_strong_random_secret
# Windows example:
# CANYU_DATA_DIR=C:\\Users\\<User>\\AppData\\Roaming\\CanyuShipping
# CANYU_DB_PATH=C:\\Users\\<User>\\AppData\\Roaming\\CanyuShipping\\shipping.db
# CANYU_BACKUP_DIR=C:\\Users\\<User>\\AppData\\Roaming\\CanyuShipping\\backups

# WSL/Linux example:
# CANYU_DATA_DIR=/home/<user>/.canyu_shipping
# CANYU_DB_PATH=/home/<user>/.canyu_shipping/shipping.db
# CANYU_BACKUP_DIR=/home/<user>/.canyu_shipping/backups
